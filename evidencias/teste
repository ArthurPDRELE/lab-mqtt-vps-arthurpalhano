#include <WiFi.h>
#include <PubSubClient.h>

// Configurações da Rede WiFi do Simulador
const char* ssid = "Wokwi-GUEST";
const char* password = "";

// Configurações do Broker MQTT Público
const char* mqtt_server = "broker.emqx.io"; // Usamos um broker público para o teste no simulador

// Definição do Pino do Sensor (Slide Switch)
const int pinoSensor = 23; 
int estadoAnterior = -1;

WiFiClient espClient;
PubSubClient client(espClient);

void setup_wifi() {
  delay(10);
  Serial.println();
  Serial.print("Conectando a ");
  Serial.println(ssid);

  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("");
  Serial.println("WiFi conectado");
  Serial.println("Endereço IP: ");
  Serial.println(WiFi.localIP());
}

void reconnect() {
  // Loop até que estejamos reconectados
  while (!client.connected()) {
    Serial.print("Tentando conexão MQTT...");
    // Tenta conectar
    if (client.connect("ESP32_Estoque_Client_Wokwi")) {
      Serial.println("conectado");
    } else {
      Serial.print("falhou, rc=");
      Serial.print(client.state());
      Serial.println(" tentando novamente em 5 segundos");
      // Aguarda 5 segundos antes de tentar novamente
      delay(5000);
    }
  }
}

void setup() {
  Serial.begin(115200);
  setup_wifi();
  client.setServer(mqtt_server, 1883);

  // Ativa o resistor interno (PULLUP)
  pinMode(pinoSensor, INPUT_PULLUP);
}

void loop() {
  if (!client.connected()) {
    reconnect();
  }
  client.loop();

  // Lê o estado do sensor (Invertido, pois INPUT_PULLUP lê LOW quando o switch está no GND)
  int estadoAtual = !digitalRead(pinoSensor); 

  // Se o estado mudou, publica a mensagem
  if (estadoAtual != estadoAnterior) {
    Serial.print("Mudança de estado detectada: ");
    Serial.println(estadoAtual);

    // Publica no tópico que definimos
    client.publish("empresa/estoque/porta/status", estadoAtual ? "1" : "0");
    
    // Se estiver aberto, publica o alerta
    if (estadoAtual == 1) {
      client.publish("empresa/estoque/sistema/alerta", "PORTA_ABERTA_ALERTA");
    }
    
    estadoAnterior = estadoAtual;
    delay(500); // Debounce para evitar leituras falsas na simulação
  }
}
